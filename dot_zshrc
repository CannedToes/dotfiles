export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="simple"

plugins=(git zsh-autosuggestions zsh-syntax-highlighting sudo copyfile copybuffer dirhistory history)

source $ZSH/oh-my-zsh.sh

alias so="source ~/.zshrc"
alias ohmyzsh="nvim ~/.oh-my-zsh"
alias rbld="sudo nixos-rebuild switch --flake ~/.config/nixos#$HOST"
alias neofetch="fastfetch"
